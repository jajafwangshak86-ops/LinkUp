# API Configuration
EXPO_PUBLIC_API_URL=https://solapp-backend.onrender.com/api
# For Android emulator, use: http://10.0.2.2:3000/api
# For iOS simulator, use: http://localhost:3000/api

# Pusher Configuration
EXPO_PUBLIC_PUSHER_KEY=657d9ddc132b0d31d851
EXPO_PUBLIC_PUSHER_CLUSTER=mt1

# Stacks Network: 'mainnet' or 'testnet'
EXPO_PUBLIC_STACKS_NETWORK=testnet

# Deployed solapp-custody contract address (deployer principal)
EXPO_PUBLIC_CUSTODY_CONTRACT_ADDRESS=

# Backend env vars (not exposed to mobile)
STACKS_NETWORK=testnet
SOLAPP_CUSTODY_CONTRACT_ADDRESS=
# Encrypted private key store — backend manages user keys server-side
ENCRYPTION_KEY=<32-byte hex key>
